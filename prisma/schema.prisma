// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  EMPLOYER
  ADMIN
}

enum JobType {
  FULL_TIME
  INTERNSHIP
  PART_TIME
  CONTRACT
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

enum EventType {
  CAREER_FAIR
  INFO_SESSION
  WORKSHOP
  NETWORKING
  INTERVIEW
  OTHER
}

model User {
  id            String    @id @default(uuid())
  auth0Id       String    @unique
  email         String    @unique
  role          UserRole
  firstName     String?
  lastName      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  studentProfile   StudentProfile?
  employerProfile  EmployerProfile?
  adminProfile     AdminProfile?

  @@index([auth0Id])
  @@index([email])
}

model StudentProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Profile Information
  phone            String?
  university       String?
  major            String?
  graduationYear   Int?
  gpa              Float?
  bio              String?   @db.Text
  linkedinUrl      String?
  portfolioUrl     String?

  // Resume
  resumeUrl        String?
  resumeUpdatedAt  DateTime?

  // Skills and interests (comma-separated or JSON)
  skills           String?   @db.Text
  interests        String?   @db.Text

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  experiences      Experience[]
  education        Education[]
  applications     Application[]
  eventRegistrations EventRegistration[]
  resumeData       ResumeData?

  @@index([userId])
  @@index([university])
  @@index([graduationYear])
}

model Experience {
  id               String    @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  title            String
  company          String
  location         String?
  startDate        DateTime
  endDate          DateTime?
  current          Boolean   @default(false)
  description      String?   @db.Text

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([studentProfileId])
}

model Education {
  id               String    @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  institution      String
  degree           String
  field            String?
  startDate        DateTime
  endDate          DateTime?
  current          Boolean   @default(false)
  gpa              Float?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([studentProfileId])
}

model ResumeData {
  id               String    @id @default(uuid())
  studentProfileId String    @unique
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  // LaTeX template data stored as JSON
  templateData     String    @db.Text
  pdfUrl           String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([studentProfileId])
}

model EmployerProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName      String
  companyLogo      String?
  companyWebsite   String?
  industry         String?
  description      String?   @db.Text
  contactEmail     String?
  contactPhone     String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  jobPostings      JobPosting[]
  events           Event[]

  @@index([userId])
  @@index([companyName])
}

model JobPosting {
  id               String    @id @default(uuid())
  employerProfileId String
  employerProfile  EmployerProfile @relation(fields: [employerProfileId], references: [id], onDelete: Cascade)

  title            String
  description      String    @db.Text
  requirements     String?   @db.Text
  jobType          JobType
  location         String?
  salary           String?
  externalUrl      String?   // If linking to external job posting

  // Targeting
  targetKeywords   String?   @db.Text // Comma-separated or JSON array
  targetUniversities String? @db.Text
  targetMajors     String?   @db.Text
  targetGradYears  String?   @db.Text

  isActive         Boolean   @default(true)
  deadline         DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  applications     Application[]

  @@index([employerProfileId])
  @@index([jobType])
  @@index([isActive])
  @@index([createdAt])
}

model Application {
  id               String    @id @default(uuid())
  jobPostingId     String
  jobPosting       JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  status           ApplicationStatus @default(PENDING)
  coverLetter      String?   @db.Text
  customResumeUrl  String?

  appliedAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([jobPostingId, studentProfileId])
  @@index([jobPostingId])
  @@index([studentProfileId])
  @@index([status])
  @@index([appliedAt])
}

model Event {
  id               String    @id @default(uuid())
  employerProfileId String
  employerProfile  EmployerProfile @relation(fields: [employerProfileId], references: [id], onDelete: Cascade)

  title            String
  description      String?   @db.Text
  eventType        EventType
  location         String?
  virtualLink      String?
  startTime        DateTime
  endTime          DateTime
  capacity         Int?

  isActive         Boolean   @default(true)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  registrations    EventRegistration[]

  @@index([employerProfileId])
  @@index([eventType])
  @@index([startTime])
  @@index([isActive])
}

model EventRegistration {
  id               String    @id @default(uuid())
  eventId          String
  event            Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  reminderSent     Boolean   @default(false)
  attended         Boolean?

  registeredAt     DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([eventId, studentProfileId])
  @@index([eventId])
  @@index([studentProfileId])
  @@index([registeredAt])
}

model AdminProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationName String?
  organizationType String?   // University, Student Group, etc.

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
}
